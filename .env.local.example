# ---------------------------------------------------------------------------
# Copy to `.env.local`. With nothing set: AI parsing falls back to the built-in
# heuristic, Rail A (bAP3X LayerZero OFT) is LIVE with on-chain-verified
# defaults, and Rail B (NEAR Intents) is LIVE with a 0.2% no-auth fee.
# Nothing here is required to boot the app.
# ---------------------------------------------------------------------------

# --- Server-side secrets (never exposed to the browser) ---
# Claude parsing. Without it, /api/parse uses the regex heuristic parser.
ANTHROPIC_API_KEY=
# NEAR Intents 1-Click partner JWT. Optional — removes the 0.2% fee.
# Register at https://docs.near-intents.org
ONECLICK_JWT=

# --- Wallet ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Rail A: bAP3X LayerZero OFT on Base (LIVE BY DEFAULT) ---
# Defaults are baked into the app and verified on-chain (2026-06-11):
#   OFT  0x9208d82f121806a34a39bb90733b4c5c54f3993e  (name/symbol bAP3X,
#        18 decimals, oftVersion() = OFT v2, canonical LayerZero EndpointV2)
#   EID  30384  (from the OFT's own PeerSet events; other peer 30102 = BNB)
# Set these ONLY to override the built-in defaults:
NEXT_PUBLIC_BAP3X_OFT_BASE=
NEXT_PUBLIC_AP3X_LZ_EID=

# --- Safety ---
# Per-transaction USD cap; above it the user must retype the amount. Default 1000.
NEXT_PUBLIC_SPEND_CAP_USD=1000
