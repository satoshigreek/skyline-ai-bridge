# ---------------------------------------------------------------------------
# Copy to `.env.local`. With nothing set: AI parsing falls back to the built-in
# heuristic, Rail A (Skyline OFT) runs in mock simulation, and Rail B
# (NEAR Intents) runs LIVE with a 0.2% no-auth fee. Nothing here is required
# to boot the app.
# ---------------------------------------------------------------------------

# --- Server-side secrets (never exposed to the browser) ---
# Claude parsing. Without it, /api/parse uses the regex heuristic parser.
ANTHROPIC_API_KEY=
# NEAR Intents 1-Click partner JWT. Optional — removes the 0.2% fee.
# Register at https://docs.near-intents.org
ONECLICK_JWT=

# --- Wallet ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Rail A: Skyline / LayerZero OFT on Base (placeholders => mock mode) ---
# bAP3X native OFT contract on Base.
NEXT_PUBLIC_BAP3X_OFT_BASE=
# USDC OFT Adapter on Base (wraps canonical Circle USDC 0x8335...2913).
NEXT_PUBLIC_USDC_OFT_ADAPTER_BASE=
# LayerZero v2 endpoint id of the Apex Fusion destination chain.
NEXT_PUBLIC_AP3X_LZ_EID=
# Force mock even when addresses are set ("true"/"false"). Auto-mocks when unset.
NEXT_PUBLIC_MOCK_MODE=

# --- Safety ---
# Per-transaction USD cap; above it the user must retype the amount. Default 1000.
NEXT_PUBLIC_SPEND_CAP_USD=1000
