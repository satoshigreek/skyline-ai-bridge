{
  "name": "skyline-bridge",
  "version": "1.0.0",
  "private": true,
  "description": "Skyline AI Bridge — plain-English cross-chain bridging on Base via Skyline (LayerZero OFT) and NEAR Intents (1-Click API).",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "test": "vitest run",
    "eval:parser": "tsx scripts/eval-parser.ts",
    "build:engine-bundle": "esbuild src/lib/engine-browser.ts --bundle --format=iife --global-name=SkylineEngine --banner:js=\"var process=(typeof process!=='undefined')?process:{env:{}};\" --minify --outfile=docs/engine-bundle.js",
    "build:wallet-bundle": "esbuild src/lib/wallet-browser.ts --bundle --format=iife --global-name=SkylineWallet --banner:js=\"var global=globalThis;\" --minify --outfile=docs/wallet-bundle.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@cardano-foundation/cardano-connect-with-wallet": "^0.2.22",
    "@cardano-foundation/cardano-connect-with-wallet-core": "^0.2.12",
    "@emurgo/cardano-serialization-lib-asmjs": "^14.1.2",
    "@rainbow-me/rainbowkit": "^2.2.4",
    "@tanstack/react-query": "^5.66.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "viem": "^2.23.2",
    "wagmi": "^2.14.11",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
